{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "fypd",
  "version": "1.2.0",
  "identifier": "com.fypd.factory",
  "build": {
    "frontendDist": "../../dist_frontend",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "fypd",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/doctorrajvanshi/fypd-OpenOpus/releases/latest/download/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzMDk1M0I2MDM1QjhFRkEKUldUNmpsc0R0bE1KczdyQys1dDB6YzFXdUIvVytESzkxZXIzRGZNby9zRUYwZnpsV3pyOGhFQlMK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../app_server.py": "app_server.py",
      "../../viral_clipper.py": "viral_clipper.py",
      "../../social_publisher.py": "social_publisher.py",
      "../../requirements.txt": "requirements.txt",
      "../../bin/": "bin/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "nsis/addpath.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
